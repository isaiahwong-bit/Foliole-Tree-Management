# Quote form email delivery (Resend — https://resend.com)
# Until RESEND_API_KEY and QUOTE_TO_EMAIL are both set, quote submissions
# are logged to the server console instead of being emailed.
RESEND_API_KEY=
QUOTE_TO_EMAIL=jordan@example.com
# Optional: a verified sender on your Resend domain.
# Defaults to "LumberJord Website <onboarding@resend.dev>" (testing only).
QUOTE_FROM_EMAIL=

# Kelpie lead ledger webhook (Digital Artifacts). Leave empty until the
# workflow is live; the forward skips silently when unset.
KELPIE_WEBHOOK_URL=
